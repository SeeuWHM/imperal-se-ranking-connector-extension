  "app_id": "se-ranking-connector",
  "version": "1.0.0",
  "name": "SE Ranking Connector",
  "description": "SEO rank tracking and keyword research powered by SE Ranking: project rankings, content opportunities (quick wins, CTR gaps), keyword research (longtail/related/questions), domain analysis and project health audits. Connect your own SE Ranking account to track your own projects.",
