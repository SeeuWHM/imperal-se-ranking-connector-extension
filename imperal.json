        "properties": {
          "projects": {
            "items": {
              "$ref": "#/$defs/ProjectRecord"
            },
            "title": "Projects",
            "type": "array"
          },
          "count": {
            "default": 0,
            "title": "Count",
            "type": "integer"
          }
